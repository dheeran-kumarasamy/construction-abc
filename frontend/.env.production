# Backend API URL for production/preview deployments
# This is used when VITE_API_URL is not set in Vercel environment variables
# Set this in Vercel project environment variables to your current Railway backend URL.
# Example: VITE_API_URL=https://your-service-name.up.railway.app
VITE_API_URL=https://backend-production-cb53.up.railway.app
