{
  "compilerOptions": {
    "rootDir": ".",
    "outDir": "dist",

    "target": "ES2020",
    "module": "Node16",
    "moduleResolution": "node16",

    "strict": true,
    "skipLibCheck": true,
    "sourceMap": true,
    "declaration": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,

    "types": ["node"]
  },
  "include": ["src/**/*", "api/**/*"]
}
