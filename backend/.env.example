# Database Configuration
DATABASE_URL=postgresql://localhost/construction_db

# Server Configuration
PORT=3001
NODE_ENV=development
JWT_SECRET=replace_with_a_long_random_secret

# LLM / Google AI Studio (Gemini) Configuration
GEMINI_API_KEY=AIzaSyDFg7XV-UqU-jLoB44uNq7at3p4zrvKjvQ
# Alternative name supported by code:
# GOOGLE_AI_API_KEY=
LLM_MODEL=gemini-3.1-pro-preview
LLM_HARD_FAIL=true

# Scraper config
SCRAPER_INDIAMART_ENABLED=true
SCRAPER_PWD_ENABLED=true
SCRAPER_RATE_LIMIT_MS=2000
SCRAPER_USER_AGENTS=
SCRAPER_PROXY_URL=
PWD_SOR_PDF_PATH=

# Price alert config
PRICE_ANOMALY_THRESHOLD=0.30

# Email / Invite SMTP config (generic)
# For most providers (including Brevo), keep TLS STARTTLS setup:
# - port 587 + SMTP_SECURE=false
# - port 465 + SMTP_SECURE=true
SMTP_HOST=smtp-relay.brevo.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
SMTP_SECURE=false

# Brevo convenience aliases (optional). If SMTP_USER/SMTP_PASS are set,
# they take precedence over these.
BREVO_SMTP_HOST=smtp-relay.brevo.com
BREVO_SMTP_PORT=587
BREVO_SMTP_LOGIN=
BREVO_SMTP_KEY=
BREVO_SMTP_FROM=
